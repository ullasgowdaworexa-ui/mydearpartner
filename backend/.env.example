# Razorpay test credentials. Replace all three values with live credentials
# before production deployment; never commit real keys.
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_with_razorpay_test_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_webhook_signing_secret
# Local/demo only: simulates checkout and never contacts Razorpay or charges money.
RAZORPAY_DEMO_MODE=false
