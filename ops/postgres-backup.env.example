# Copy outside the repository (for example, /etc/matiromony/postgres-backup.env),
# set permissions to 0600, and load it from the scheduler. Do not commit it.

# Primary database connection. Prefer PGPASSFILE (0600) or a secret-manager
# injected password over placing PGPASSWORD in this file.
PGHOST=postgres-primary.internal
PGPORT=5432
PGDATABASE=matiromony
PGUSER=backup_reader
PGPASSFILE=/run/secrets/postgres-backup.pgpass

# Both directories must be writable/readable by the backup runner. The database
# path should be the host mount that backs db_data, so its capacity is checked.
BACKUP_LOCAL_DIR=/var/backups/matiromony/postgresql
BACKUP_DATABASE_DISK_PATH=/var/lib/docker/volumes/matiromony_db_data/_data

# A public age recipient; keep the corresponding identity in a separate,
# access-controlled recovery location. BACKUP_REMOTE_URL must be a dedicated
# prefix, never a broad bucket/root. Example: mdp-offsite:prod/postgresql
BACKUP_AGE_RECIPIENT=age1replace_with_production_recovery_public_key
BACKUP_REMOTE_URL=mdp-offsite:production/postgresql
BACKUP_RETENTION_DAYS=30
BACKUP_PRUNE_REMOTE=1

# Alerting gateway endpoint stored in the deployment secret manager.
BACKUP_ALERT_WEBHOOK_URL=https://alerts.example.invalid/hooks/postgres-backup
BACKUP_WARN_PERCENT=70
BACKUP_HIGH_PERCENT=80
BACKUP_CRITICAL_PERCENT=85
# Peak local space: unencrypted dump + encrypted working copy + retained copy,
# while preserving at least 5 GiB and the configured 85% emergency headroom.
BACKUP_SPACE_MULTIPLIER=3
BACKUP_MIN_FREE_BYTES=5368709120
